{
  "HTTP_PORTS": "8080",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GitCandy": {
    "Application": {
      "UserConfigurationPath": "/var/lib/gitcandy/config.xml",
      "IsPublicServer": true,
      "ForceSsl": false,
      "SslPort": 443,
      "LocalSkipCustomError": true,
      "AllowRegisterUser": true,
      "AllowRepositoryCreation": true,
      "RepositoryPath": "/var/lib/gitcandy/repositories",
      "CachePath": "/var/lib/gitcandy/cache",
      "GitCorePath": "",
      "NumberOfCommitsPerPage": 30,
      "NumberOfItemsPerList": 30,
      "NumberOfRepositoryContributors": 50,
      "SshPort": 2222,
      "EnableSsh": true,
      "SshHostKeyPath": "/var/lib/gitcandy/ssh-host-key.xml",
      "DataProtectionKeysPath": "/var/lib/gitcandy/data-protection-keys"
    },
    "GitHttp": {
      "MaxRequestBodySize": 4294967296,
      "RequestTimeout": "00:30:00",
      "StreamBufferSize": 81920,
      "MaxConcurrentOperations": 16
    },
    "Identity": {
      "Password": {
        "RequiredLength": 12,
        "RequiredUniqueChars": 4,
        "RequireDigit": true,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNonAlphanumeric": true
      },
      "OpenIdConnect": {
        "Enabled": false,
        "DisplayName": "OpenID Connect",
        "Authority": "",
        "ClientId": "",
        "ClientSecret": "",
        "CallbackPath": "/signin-oidc",
        "RequireHttpsMetadata": true
      }
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionStringName": "GitCandy",
      "DbContextPoolSize": 128,
      "EnableSensitiveDataLogging": false
    },
    "Observability": {
      "Enabled": true,
      "ServiceName": "GitCandy",
      "TraceSamplingRatio": 1.0,
      "ConsoleExporterEnabled": false,
      "Otlp": {
        "Enabled": false,
        "Endpoint": ""
      }
    }
  },
  "ConnectionStrings": {
    "GitCandy": "Data Source=/var/lib/gitcandy/GitCandy.db"
  },
  "AllowedHosts": "*"
}
