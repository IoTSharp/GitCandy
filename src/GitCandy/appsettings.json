{
  "HTTP_PORTS": "8080",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.GitCandy.EnterpriseProviders": "Warning"
    }
  },
  "GitCandy": {
    "Application": {
      "UserConfigurationPath": "/var/lib/gitcandy/config.xml",
      "IsPublicServer": true,
      "ForceSsl": false,
      "SslPort": 443,
      "LocalSkipCustomError": true,
      "AllowRegisterUser": true,
      "AllowRepositoryCreation": true,
      "RepositoryPath": "/var/lib/gitcandy/repositories",
      "CachePath": "/var/lib/gitcandy/cache",
      "GitCorePath": "",
      "NumberOfCommitsPerPage": 30,
      "NumberOfItemsPerList": 30,
      "NumberOfRepositoryContributors": 50,
      "AllowAuthorApproval": false,
      "DismissStalePullRequestApprovals": true,
      "RequiredPullRequestApprovals": 1,
      "SshPort": 2222,
      "EnableSsh": true,
      "SshHostKeyPath": "/var/lib/gitcandy/ssh-host-key.xml",
      "DataProtectionKeysPath": "/var/lib/gitcandy/data-protection-keys"
    },
    "Proxy": {
      "Enabled": false,
      "ForwardLimit": 1,
      "KnownProxies": []
    },
    "GitHttp": {
      "MaxRequestBodySize": 4294967296,
      "RequestTimeout": "00:30:00",
      "StreamBufferSize": 81920,
      "MaxConcurrentOperations": 16
    },
    "Namespaces": {
      "AliasRetentionDays": 365,
      "RenameLimit": 3,
      "RenameWindowDays": 7
    },
    "RepositoryBrowser": {
      "MaxDisplayedBlobBytes": 1048576,
      "MaxDiffCharacters": 2097152,
      "MaxDiffFiles": 500,
      "MaxArchiveBytes": 1073741824,
      "MaxArchiveEntries": 100000,
      "MaxStatisticsCommits": 10000,
      "MaxContributors": 100,
      "OperationTimeout": "00:02:00"
    },
    "Lfs": {
      "Enabled": true,
      "MaxObjectBytes": 4294967296,
      "RepositoryQuotaBytes": 0,
      "StreamBufferSize": 131072,
      "OperationTimeout": "00:30:00"
    },
    "OpenSsh": {
      "Enabled": false,
      "ExecutablePath": ""
    },
    "Webhooks": {
      "AllowHttpTargets": false,
      "AllowPrivateNetworkTargets": false,
      "RequestTimeout": "00:00:10",
      "ConnectTimeout": "00:00:05",
      "MaxAttempts": 6,
      "DeliveryBatchSize": 20,
      "MaxResponseBytes": 4096,
      "MaxSubscriptionsPerRepository": 20
    },
    "Releases": {
      "MaxAssetBytes": 104857600,
      "MaxTotalAssetBytes": 1073741824,
      "MaxAssetsPerRelease": 20,
      "OrphanRetention": "1.00:00:00"
    },
    "Identity": {
      "AccountRecovery": {
        "TokenLifespan": "01:00:00",
        "MaxRequestsPerWindow": 5,
        "RequestWindow": "00:15:00",
        "Smtp": {
          "Host": "",
          "Port": 587,
          "EnableSsl": true,
          "UserName": "",
          "Password": "",
          "FromAddress": ""
        }
      },
      "Password": {
        "RequiredLength": 12,
        "RequiredUniqueChars": 4,
        "RequireDigit": true,
        "RequireLowercase": true,
        "RequireUppercase": true,
        "RequireNonAlphanumeric": true
      },
      "OpenIdConnect": {
        "Enabled": false,
        "DisplayName": "OpenID Connect",
        "Authority": "",
        "ClientId": "",
        "ClientSecret": "",
        "CallbackPath": "/signin-oidc",
        "RequireHttpsMetadata": true
      }
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionStringName": "GitCandy",
      "DbContextPoolSize": 128,
      "EnableSensitiveDataLogging": false
    },
    "Observability": {
      "Enabled": true,
      "ServiceName": "GitCandy",
      "TraceSamplingRatio": 1.0,
      "ConsoleExporterEnabled": false,
      "Otlp": {
        "Enabled": false,
        "Endpoint": ""
      }
    }
  },
  "ConnectionStrings": {
    "GitCandy": "Data Source=/var/lib/gitcandy/GitCandy.db"
  },
  "AllowedHosts": "*"
}
