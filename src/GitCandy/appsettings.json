{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GitCandy": {
    "Application": {
      "LogPathFormat": "App_Data/{0}.log",
      "UserConfigurationPath": "App_Data/config.xml",
      "IsPublicServer": true,
      "ForceSsl": false,
      "SslPort": 443,
      "LocalSkipCustomError": true,
      "AllowRegisterUser": true,
      "AllowRepositoryCreation": true,
      "RepositoryPath": "App_Data/Repos",
      "CachePath": "App_Data/Caches",
      "GitCorePath": "",
      "NumberOfCommitsPerPage": 30,
      "NumberOfItemsPerList": 30,
      "NumberOfRepositoryContributors": 50,
      "SshPort": 22,
      "EnableSsh": true,
      "SshHostKeyPath": "App_Data/ssh-host-key.xml"
    },
    "GitHttp": {
      "MaxRequestBodySize": 4294967296,
      "RequestTimeout": "00:30:00",
      "StreamBufferSize": 81920,
      "MaxConcurrentOperations": 16
    },
    "Database": {
      "Provider": "Sqlite",
      "ConnectionStringName": "GitCandy",
      "DbContextPoolSize": 128,
      "EnableSensitiveDataLogging": false
    }
  },
  "ConnectionStrings": {
    "GitCandy": "Data Source=App_Data/GitCandy.db"
  },
  "AllowedHosts": "*"
}
