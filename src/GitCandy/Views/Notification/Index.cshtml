@model NotificationIndexViewModel
@{ ViewData["Title"] = "Notifications"; }
<header class="page-heading"><div><h1>Notifications</h1><p>Events delivered to you. Reading a notification does not complete its Todo.</p></div><div class="button-row"><a class="btn" asp-action="Preferences"><i data-lucide="settings"></i> Delivery</a><form asp-action="ReadAll" method="post"><button class="btn" type="submit"><i data-lucide="check-check"></i> Mark all read</button></form></div></header>
<form class="inbox-filters" method="get"><label><input type="checkbox" name="unread" value="true" checked="@Model.Query.UnreadOnly" /> Unread only</label><select name="reason"><option value="">All reasons</option>@foreach (var value in Enum.GetValues<GitCandy.Workspace.WorkspaceNotificationReason>()) { <option value="@value" selected="@(Model.Query.Reason == value)">@value</option> }</select><select name="resourceType"><option value="">All resources</option>@foreach (var value in Enum.GetValues<GitCandy.Workspace.WorkspaceResourceType>()) { <option value="@value" selected="@(Model.Query.ResourceType == value)">@value</option> }</select><label><input type="checkbox" name="team" value="true" checked="@Model.Query.TeamOnly" /> Team source</label><button class="btn" type="submit"><i data-lucide="list-filter"></i> Filter</button></form>
@if (Model.Page.Items.Count == 0) { <section class="empty-state"><div><i data-lucide="inbox"></i><h2>Inbox is clear</h2></div></section> }
else { <div class="notification-list">@foreach (var item in Model.Page.Items) { <article class="notification-item @(item.ReadAtUtc is null ? "is-unread" : null)"><i data-lucide="bell"></i><div><a href="@item.Url"><strong>@item.Title</strong></a><p>@item.EventType · @item.Reason · @item.ResourceType by @(item.Actor ?? "GitCandy") · @item.CreatedAtUtc.ToString("u")</p></div>@if (item.ReadAtUtc is null) { <form asp-action="Read" asp-route-id="@item.Id" method="post"><button class="icon-button" type="submit" aria-label="Mark as read" data-tooltip="Mark as read"><i data-lucide="check"></i></button></form> }</article> }</div> }
