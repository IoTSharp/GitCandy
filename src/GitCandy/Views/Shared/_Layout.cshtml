<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GitCandy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="site-brand" asp-area="" asp-controller="Home" asp-action="Index">GitCandy</a>
        <nav class="account-navigation" aria-label="Account">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Change">@User.Identity.Name</a>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="link-button">Sign out</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login">Sign in</a>
                <a asp-controller="Account" asp-action="Create">Create account</a>
            }
        </nav>
    </header>
    <main class="site-main" role="main">
        @RenderBody()
    </main>

    <footer class="site-footer" title="@Context.GetGitCandyRequestProfiler()?.Elapsed">
        &copy; 2026 - GitCandy
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
