@model TeamIndexViewModel
@{
    ViewData["Title"] = Text["Team_ListTitle"];
}
<h4>@Text["Team_ListTitle"]</h4>
<form asp-action="Index" method="get" class="row">
    <div class="form-group col-md-5"><div class="input-group"><input type="search" name="query" value="@Model.Query" class="form-control" /><span class="input-group-btn"><button type="submit" class="btn btn-default">@Text["Shared_Search"]</button></span></div></div>
</form>
<p class="text-right"><a asp-action="Create" class="btn btn-primary">@Text["Shared_Create"]</a></p>
<table class="table table-hover table-striped">
    <thead><tr><th>Name</th><th>Description</th><th>Members</th></tr></thead>
    <tbody>
    @foreach (var team in Model.Teams)
    {
        <tr><td><a asp-action="Detail" asp-route-name="@team.Name">@team.Name</a></td><td>@team.Description</td><td>@team.MemberCount</td></tr>
    }
    </tbody>
</table>
