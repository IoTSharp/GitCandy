@model TeamIndexViewModel
@{ ViewData["Title"] = Text["Team_ListTitle"]; }
<header class="page-heading"><div><h1>@Text["Team_ListTitle"]</h1><p>Manage teams, membership, and repository relationships.</p></div><div class="page-actions"><a asp-action="Create" class="btn btn-primary"><i data-lucide="plus"></i> @Text["Shared_Create"]</a></div></header>
<form asp-action="Index" method="get" class="filter-bar" role="search"><div class="input-group"><input type="search" name="query" value="@Model.Query" aria-label="Search teams" /><span class="input-group-btn"><button type="submit" class="btn" aria-label="Search"><i data-lucide="search"></i></button></span></div></form>
@if (Model.Teams.Count == 0)
{
    <section class="empty-state"><div><i data-lucide="users"></i><h2>No teams found</h2><p>Change the search query or create a team.</p></div></section>
}
else
{
    <div class="table-responsive"><table class="table table-hover"><thead><tr><th scope="col">Name</th><th scope="col">Description</th><th scope="col">Members</th></tr></thead><tbody>
    @foreach (var team in Model.Teams) { <tr><td><a asp-action="Detail" asp-route-name="@team.Name">@team.Name</a></td><td>@(string.IsNullOrWhiteSpace(team.Description) ? "No description" : team.Description)</td><td>@team.MemberCount</td></tr> }
    </tbody></table></div>
}
