@model string
@{ ViewData["Title"] = $"Delete {Model}"; }
<header class="page-heading"><div><h1>Delete @Model</h1><p>This destructive action cannot be undone.</p></div></header>
<div class="alert alert-danger" role="alert">The team and its repository relationships will be deleted.</div>
<form asp-action="Delete" asp-route-name="@Model" method="post" class="form-actions" data-confirm="Delete team @Model?"><a asp-action="Detail" asp-route-name="@Model" class="btn"><i data-lucide="arrow-left"></i> @Text["Shared_Back"]</a><button type="submit" class="btn btn-danger"><i data-lucide="trash-2"></i> @Text["Shared_Delete"]</button></form>
