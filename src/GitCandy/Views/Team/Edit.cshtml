@model TeamFormViewModel
@{ ViewData["Title"] = $"Edit {Model.Name}"; }
<header class="page-heading"><div><h1>Edit @Model.Name</h1><p>Update the team description. Membership is managed separately.</p></div></header>
<form asp-action="Edit" asp-route-name="@Model.Name" method="post" class="account-form">
    <input asp-for="Name" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
    <div class="form-field"><label asp-for="DisplayName"></label><input asp-for="DisplayName" autocomplete="organization" /><span asp-validation-for="DisplayName"></span></div>
    <div class="form-field"><label asp-for="Description"></label><textarea asp-for="Description" rows="4"></textarea><span asp-validation-for="Description"></span></div>
    <div class="form-actions"><button type="submit" class="btn btn-primary"><i data-lucide="check"></i> @Text["Shared_Save"]</button><a asp-action="Detail" asp-route-name="@Model.Name" class="btn"><i data-lucide="arrow-left"></i> @Text["Shared_Back"]</a><a asp-action="Rename" asp-route-name="@Model.Name" class="btn"><i data-lucide="pencil"></i> Rename URL</a>@if (User.IsInRole(RoleNames.Administrator)) { <a asp-action="Delete" asp-route-name="@Model.Name" class="btn btn-danger"><i data-lucide="trash-2"></i> @Text["Shared_Delete"]</a> }</div>
</form>
