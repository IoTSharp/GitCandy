@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    var returnUrl = ViewData["returnUrl"] as string;
}

<section class="account-shell">
    <h1>Sign in</h1>
    <p class="page-subtitle">Use your GitCandy account to access private repositories and credentials.</p>
    <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="account-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
        <div class="form-field">
            <label asp-for="UserNameOrEmail"></label>
            <input asp-for="UserNameOrEmail" autocomplete="username" autofocus />
            <span asp-validation-for="UserNameOrEmail"></span>
        </div>
        <div class="form-field">
            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" />
            <span asp-validation-for="Password"></span>
        </div>
        <label class="checkbox-field">
            <input asp-for="RememberMe" />
            <span>@Html.DisplayNameFor(model => model.RememberMe)</span>
        </label>
        <div class="form-actions">
            <button type="submit" class="primary-button"><i data-lucide="log-in"></i> Sign in</button>
            <a asp-action="Create">Create account</a>
            <a asp-action="Forgot">Forgot password?</a>
        </div>
    </form>
    @if (Model.ExternalProviders.Count > 0)
    {
        <hr />
        <div class="external-login-list">
            @foreach (var provider in Model.ExternalProviders)
            {
                <form asp-controller="AccountSecurity" asp-action="ExternalLogin" asp-route-returnUrl="@returnUrl" method="post">
                    <button type="submit" name="provider" value="@provider.Scheme" class="btn">
                        Sign in with @provider.DisplayName
                    </button>
                </form>
            }
        </div>
    }
</section>
