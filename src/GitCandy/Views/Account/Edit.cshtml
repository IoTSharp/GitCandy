@model EditAccountViewModel
@{
    ViewData["Title"] = $"Edit {Model.UserName}";
}
<header class="page-heading"><div><h1>Edit @Model.UserName</h1><p>Profile changes require your current password.</p></div></header>
<form asp-action="Edit" method="post" class="account-form">
    <input asp-for="UserName" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
    <div class="form-field"><label asp-for="DisplayName"></label><input asp-for="DisplayName" autocomplete="name" /><span asp-validation-for="DisplayName"></span></div>
    <div class="form-field"><label asp-for="Email"></label><input asp-for="Email" autocomplete="email" /><span asp-validation-for="Email"></span></div>
    <div class="form-field"><label asp-for="Description"></label><textarea asp-for="Description" rows="4"></textarea><span asp-validation-for="Description"></span></div>
    @if (User.IsInRole(RoleNames.Administrator))
    {
        <div class="form-field checkbox-field"><input asp-for="IsAdministrator" /><label asp-for="IsAdministrator"></label><span asp-validation-for="IsAdministrator"></span></div>
    }
    <div class="form-field"><label asp-for="CurrentPassword"></label><input asp-for="CurrentPassword" autocomplete="current-password" /><span asp-validation-for="CurrentPassword"></span></div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i data-lucide="check"></i> @Text["Shared_Save"]</button>
        <a asp-action="Detail" asp-route-name="@Model.UserName" class="btn"><i data-lucide="arrow-left"></i> @Text["Shared_Back"]</a>
        @if (User.IsInRole(RoleNames.Administrator)) { <a asp-action="Delete" asp-route-name="@Model.UserName" class="btn btn-danger"><i data-lucide="trash-2"></i> @Text["Shared_Delete"]</a> }
    </div>
</form>
