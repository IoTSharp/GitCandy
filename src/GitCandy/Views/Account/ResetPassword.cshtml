@model ResetPasswordViewModel
@{ ViewData["Title"] = "Reset password"; }
<section class="account-shell"><h1>Reset password</h1>
<form asp-action="ResetPassword" method="post" class="account-form">
    <input asp-for="Email" type="hidden" /><input asp-for="Token" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
    <div class="form-field"><label asp-for="NewPassword"></label><input asp-for="NewPassword" autocomplete="new-password" /><span asp-validation-for="NewPassword"></span></div>
    <div class="form-field"><label asp-for="ConfirmPassword"></label><input asp-for="ConfirmPassword" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword"></span></div>
    <button type="submit" class="primary-button"><i data-lucide="key-round"></i> Reset password</button>
</form></section>
