@model AccountIndexViewModel
@{
    ViewData["Title"] = Text["Account_ListTitle"];
}

<h4>@Text["Account_ListTitle"]</h4>
<form asp-action="Index" method="get" class="row">
    <div class="form-group col-md-5">
        <div class="input-group">
            <input type="search" name="query" value="@Model.Query" class="form-control" />
            <span class="input-group-btn"><button type="submit" class="btn btn-default">@Text["Shared_Search"]</button></span>
        </div>
    </div>
</form>
<p class="text-right"><a asp-action="Create" class="btn btn-primary">@Text["Shared_Create"]</a></p>
<table class="table table-hover table-striped">
    <thead><tr><th>Username</th><th>Display name</th><th>Email</th><th>Administrator</th></tr></thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td><a asp-action="Detail" asp-route-name="@user.UserName">@user.UserName</a></td>
            <td>@user.DisplayName</td>
            <td><a href="mailto:@user.Email">@user.Email</a></td>
            <td>@(user.IsAdministrator ? Text["Shared_Yes"] : Text["Shared_No"])</td>
        </tr>
    }
    </tbody>
</table>
