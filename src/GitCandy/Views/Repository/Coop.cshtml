@model RepositoryDetailsViewModel
@{
    ViewData["Title"] = $"Relationships - {Model.Repository.Name}";
}
<h3>Relationships for @Model.Repository.Name</h3>
<div class="row">
    <section class="col-md-6">
        <h4>@Text["Shared_Users"]</h4>
        @foreach (var user in Model.Repository.Users)
        {
            <div class="well well-sm">
                <strong>@user.UserName</strong>
                <form asp-action="ChooseUser" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="User" value="@user.UserName" /><input type="hidden" name="Act" value="read" /><input type="hidden" name="Value" value="@(!user.AllowRead)" /><button type="submit" class="btn btn-default btn-xs">Toggle read (@user.AllowRead)</button></form>
                <form asp-action="ChooseUser" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="User" value="@user.UserName" /><input type="hidden" name="Act" value="write" /><input type="hidden" name="Value" value="@(!user.AllowWrite)" /><button type="submit" class="btn btn-default btn-xs">Toggle write (@user.AllowWrite)</button></form>
                <form asp-action="ChooseUser" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="User" value="@user.UserName" /><input type="hidden" name="Act" value="owner" /><input type="hidden" name="Value" value="@(!user.IsOwner)" /><button type="submit" class="btn btn-default btn-xs">Toggle owner (@user.IsOwner)</button></form>
                <form asp-action="ChooseUser" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="User" value="@user.UserName" /><input type="hidden" name="Act" value="del" /><button type="submit" class="btn btn-danger btn-xs">@Text["Shared_Delete"]</button></form>
            </div>
        }
        <form asp-action="ChooseUser" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="Act" value="add" /><input name="User" class="form-control" placeholder="Username" required /><button type="submit" class="btn btn-primary">Add user</button></form>
    </section>
    <section class="col-md-6">
        <h4>@Text["Shared_Teams"]</h4>
        @foreach (var team in Model.Repository.Teams)
        {
            <div class="well well-sm">
                <strong>@team.TeamName</strong>
                <form asp-action="ChooseTeam" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="Team" value="@team.TeamName" /><input type="hidden" name="Act" value="read" /><input type="hidden" name="Value" value="@(!team.AllowRead)" /><button type="submit" class="btn btn-default btn-xs">Toggle read (@team.AllowRead)</button></form>
                <form asp-action="ChooseTeam" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="Team" value="@team.TeamName" /><input type="hidden" name="Act" value="write" /><input type="hidden" name="Value" value="@(!team.AllowWrite)" /><button type="submit" class="btn btn-default btn-xs">Toggle write (@team.AllowWrite)</button></form>
                <form asp-action="ChooseTeam" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="Team" value="@team.TeamName" /><input type="hidden" name="Act" value="del" /><button type="submit" class="btn btn-danger btn-xs">@Text["Shared_Delete"]</button></form>
            </div>
        }
        <form asp-action="ChooseTeam" method="post" class="form-inline"><input type="hidden" name="Name" value="@Model.Repository.Name" /><input type="hidden" name="Act" value="add" /><input name="Team" class="form-control" placeholder="Team" required /><button type="submit" class="btn btn-primary">Add team</button></form>
    </section>
</div>
<p><a asp-action="Detail" asp-route-name="@Model.Repository.Name" class="btn btn-default">@Text["Shared_Back"]</a></p>
