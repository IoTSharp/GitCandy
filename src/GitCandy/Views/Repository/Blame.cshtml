@model RepositoryBlameViewModel
@{ ViewData["Title"] = $"Blame {Model.Blame.Path}"; }
<nav class="breadcrumb" aria-label="Breadcrumb"><a asp-action="Tree" asp-route-name="@Model.RepositoryName">@Model.RepositoryName</a><span>/</span><a asp-action="Blob" asp-route-name="@Model.RepositoryName" asp-route-path="@Model.Blame.Path" asp-route-revision="@Model.Blame.Revision.CommitId">@Model.Blame.Path</a><span>/</span><span>Blame</span></nav>
<partial name="~/Views/Repository/_RepositoryNavigation.cshtml" model="Model.RepositoryName" />
<header class="page-heading"><div><h1>Blame</h1><p>@Model.Blame.Path</p></div></header>
<div class="blame-view"><table><tbody>
@foreach (var hunk in Model.Blame.Hunks)
{
    for (var index = 0; index < hunk.Lines.Count; index++)
    {
        var line = hunk.StartLine + index;
        <tr id="@($"L{line}")"><td class="blame-commit">@if (index == 0) { <a asp-action="Commit" asp-route-name="@Model.RepositoryName" asp-route-path="@hunk.CommitId">@hunk.CommitId[..8]</a><span>@hunk.AuthorName</span> }</td><td class="line-number"><a href="@($"#L{line}")">@line</a></td><td class="line-code"><code>@hunk.Lines[index]</code></td></tr>
    }
}
</tbody></table></div>
