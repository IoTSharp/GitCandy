@model RepositoryFormViewModel
@{
    var isEdit = string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Edit", StringComparison.OrdinalIgnoreCase);
}
<form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-name="@(isEdit ? Model.Name : null)" method="post" class="account-form">
    <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
    <div class="form-field">
        <label asp-for="Name"></label>
        @if (isEdit)
        {
            <input asp-for="Name" type="hidden" />
            <p class="form-control-static">@Model.Name</p>
        }
        else
        {
            <input asp-for="Name" autocomplete="off" />
            <span asp-validation-for="Name"></span>
        }
    </div>
    @if (!isEdit)
    {
        <div class="form-field">
            <label asp-for="InitializationMode"></label>
            <select asp-for="InitializationMode" asp-items="Html.GetEnumSelectList<RepositoryCreationMode>()"></select>
        </div>
        <div class="form-field">
            <label asp-for="Source"></label>
            <input asp-for="Source" autocomplete="off" placeholder="https://example.com/project.git or repository name" />
            <span asp-validation-for="Source"></span>
            <p class="form-hint">Import accepts credential-free HTTP(S), SSH or Git URLs. Fork accepts an existing readable repository name.</p>
        </div>
    }
    else
    {
        <div class="form-field">
            <label asp-for="DefaultBranch"></label>
            <input asp-for="DefaultBranch" autocomplete="off" />
            <span asp-validation-for="DefaultBranch"></span>
        </div>
    }
    <div class="form-field checkbox-field">
        <input asp-for="IsPrivate" />
        <label asp-for="IsPrivate"></label>
    </div>
    <div class="form-field checkbox-field">
        <input asp-for="AllowAnonymousRead" />
        <label asp-for="AllowAnonymousRead"></label>
    </div>
    <div class="form-field checkbox-field">
        <input asp-for="AllowAnonymousWrite" />
        <label asp-for="AllowAnonymousWrite"></label>
    </div>
    <div class="form-field">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" rows="4"></textarea>
        <span asp-validation-for="Description"></span>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i data-lucide="check"></i> @(isEdit ? Text["Shared_Save"] : Text["Shared_Create"])</button>
        <a asp-action="@(isEdit ? "Detail" : "Index")" asp-route-name="@(isEdit ? Model.Name : null)" class="btn"><i data-lucide="arrow-left"></i> @Text["Shared_Back"]</a>
        @if (isEdit)
        {
            <a asp-action="Delete" asp-route-name="@Model.Name" class="btn btn-danger"><i data-lucide="trash-2"></i> @Text["Shared_Delete"]</a>
        }
    </div>
</form>
