@model string
@{
    ViewData["Title"] = $"Delete {Model}";
}
<div class="panel panel-danger"><div class="panel-heading"><h4 class="panel-title">Confirm deletion</h4></div><div class="panel-body">Delete repository metadata for <strong>@Model</strong>? The M6 Git backend remains responsible for repository filesystem deletion.</div></div>
<form asp-action="Delete" asp-route-name="@Model" method="post"><a asp-action="Detail" asp-route-name="@Model" class="btn btn-default">@Text["Shared_Back"]</a><button type="submit" class="btn btn-danger pull-right">@Text["Shared_Delete"]</button></form>
