@model IssueMetadataViewModel
@{ ViewData["Title"] = "Issue settings"; }
<nav class="breadcrumb"><a href="@Model.Repository.CanonicalPath">@Model.Repository.NamespaceSlug/@Model.Repository.RepositorySlug</a><span>/</span><a asp-action="Index" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug">Issues</a><span>/</span><span>Settings</span></nav>
<header class="page-heading"><div><h1>Issue settings</h1><p>Repository labels and milestones.</p></div></header>
<div class="split-layout">
    <section><h2>Labels</h2><form asp-action="SaveLabel" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" method="post" class="account-form"><div class="form-field"><label for="name">Name</label><input id="name" name="name" required maxlength="50" /></div><div class="form-field"><label for="color">Color</label><input id="color" name="color" value="6e7781" pattern="[0-9A-Fa-f]{6}" required /></div><div class="form-field"><label for="description">Description</label><input id="description" name="description" maxlength="200" /></div><button class="btn btn-primary" type="submit">Add label</button></form><ul class="metadata-list">@foreach (var label in Model.Metadata.Labels) { <li><span class="issue-label" style="--label-color:#@label.Color">@label.Name</span><span>@label.Description</span>@if (!label.IsArchived) { <form asp-action="ArchiveLabel" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-labelId="@label.Id" method="post"><button class="icon-button" type="submit" aria-label="Archive label" data-tooltip="Archive label"><i data-lucide="archive"></i></button></form> }</li> }</ul></section>
    <section><h2>Milestones</h2><form asp-action="SaveMilestone" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" method="post" class="account-form"><div class="form-field"><label for="title">Title</label><input id="title" name="title" required maxlength="100" /></div><div class="form-field"><label for="dueAtUtc">Due date</label><input id="dueAtUtc" name="dueAtUtc" type="date" /></div><div class="form-field"><label for="milestone-description">Description</label><textarea id="milestone-description" name="description" rows="4" maxlength="2000"></textarea></div><button class="btn btn-primary" type="submit">Add milestone</button></form><ul class="metadata-list">@foreach (var milestone in Model.Metadata.Milestones) { <li><strong>@milestone.Title</strong><span>@milestone.OpenIssues open · @milestone.ClosedIssues closed</span>@if (!milestone.IsArchived) { <form asp-action="MilestoneStatus" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-milestoneId="@milestone.Id" method="post"><input type="hidden" name="closed" value="true" /><input type="hidden" name="archived" value="true" /><button class="icon-button" type="submit" aria-label="Close and archive milestone" data-tooltip="Close and archive"><i data-lucide="archive"></i></button></form> }</li> }</ul></section>
</div>
