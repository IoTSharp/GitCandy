@model PullRequestChangesViewModel
@{ ViewData["Title"] = $"Files changed · #{Model.PullRequest.Number}"; var additions = Model.Changes.Files.Sum(file => file.LinesAdded); var deletions = Model.Changes.Files.Sum(file => file.LinesDeleted); }
<nav class="breadcrumb" aria-label="Breadcrumb"><a href="@Model.Repository.CanonicalPath">@Model.Repository.NamespaceSlug/@Model.Repository.RepositorySlug</a><span>/</span><a asp-action="Index" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug">Pull requests</a><span>/</span><a asp-action="Detail" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number">#@Model.PullRequest.Number</a><span>/</span><span>Files changed</span></nav>
<header class="page-heading pr-subview-heading">
    <div><h1>@Model.PullRequest.Title</h1><p>@Model.Changes.Files.Count files changed · <span class="diff-additions">+@additions</span> <span class="diff-deletions">-@deletions</span></p></div>
    <code title="Merge base">base @Model.Changes.MergeBaseSha[..Math.Min(12, Model.Changes.MergeBaseSha.Length)]</code>
</header>
<nav class="repository-navigation" aria-label="Pull Request views">
    <a asp-action="Detail" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number"><i data-lucide="message-square"></i> Conversation</a>
    <a asp-action="Commits" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number"><i data-lucide="list-ordered"></i> Commits</a>
    <a class="is-active" asp-action="Files" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number"><i data-lucide="files"></i> Files changed</a>
</nav>
@if (TempData["PullRequestError"] is string error) { <div class="alert alert-warning" role="alert">@error</div> }
@if (Model.Changes.DiffTruncated) { <div class="alert alert-warning">The diff reached a configured display limit; omitted patches remain available through Git.</div> }
@if (Model.Changes.Files.Count == 0)
{
    <section class="empty-state"><div><i data-lucide="files"></i><h2>No file changes</h2></div></section>
}
@foreach (var file in Model.Changes.Files)
{
    var fileThreads = Model.ReviewThreads.Where(thread => !thread.IsOutdated
        && (string.Equals(thread.CurrentPath, file.Path, StringComparison.Ordinal)
            || string.Equals(thread.CurrentPath, file.OldPath, StringComparison.Ordinal))).ToArray();
    <section class="diff-file">
        <header>
            <strong>@if (!string.IsNullOrEmpty(file.OldPath) && !string.Equals(file.OldPath, file.Path, StringComparison.Ordinal)) { <span>@file.OldPath → </span> }@file.Path</strong>
            <span class="diff-stat">+@file.LinesAdded -@file.LinesDeleted · @file.Status</span>
        </header>
        @if (file.IsBinary) { <p class="binary-diff">Binary file changed.</p> }
        else if (file.Patch is null) { <p class="binary-diff">Patch omitted by the configured diff limit.</p> }
        else
        {
            <details class="diff-patch" open>
                <summary><i data-lucide="chevron-right"></i> Patch</summary>
                <pre><code class="language-diff" data-highlight>@file.Patch</code></pre>
            </details>
        }
        @foreach (var thread in fileThreads)
        {
            <article class="review-thread @(thread.IsResolved ? "is-resolved" : null)" id="review-thread-@thread.Id">
                <header><strong>@thread.CurrentSide @thread.CurrentStartLine@if (thread.CurrentEndLine != thread.CurrentStartLine) { <span>-@thread.CurrentEndLine</span> }</strong><span>@(thread.IsResolved ? $"Resolved by {thread.ResolvedBy}" : "Open")</span></header>
                @foreach (var comment in thread.Comments)
                {
                    <div class="review-comment"><div><strong>@comment.Author</strong><time>@comment.CreatedAtUtc.ToString("u")</time></div><div class="markdown-body">@Html.Raw(comment.BodyHtml)</div></div>
                }
                @if (Model.CanReview)
                {
                    <form class="review-reply-form" asp-action="AddReviewReply" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number" asp-route-threadId="@thread.Id" method="post"><textarea name="Body" rows="2" maxlength="65536" required aria-label="Review reply"></textarea><button class="btn btn-primary" type="submit"><i data-lucide="reply"></i> Reply</button></form>
                }
                @if (Model.CanReview && (Model.IsOwner || string.Equals(Model.CurrentUserId, thread.AuthorUserId, StringComparison.Ordinal)))
                {
                    <form class="review-resolve-form" asp-action="SetReviewThreadResolved" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number" asp-route-threadId="@thread.Id" method="post"><input type="hidden" name="resolved" value="@(!thread.IsResolved ? "true" : "false")" /><button class="btn" type="submit"><i data-lucide="@(thread.IsResolved ? "rotate-ccw" : "check")"></i> @(thread.IsResolved ? "Reopen" : "Resolve")</button></form>
                }
            </article>
        }
        @if (Model.CanReview && !file.IsBinary && file.Patch is not null && Model.PullRequest.State == PullRequestState.Open)
        {
            <details class="review-compose">
                <summary><i data-lucide="message-square-plus"></i> Add review comment</summary>
                <form asp-action="AddReviewThread" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number" method="post">
                    <input type="hidden" name="Path" value="@file.Path" />
                    <input type="hidden" name="OldPath" value="@file.OldPath" />
                    <div class="form-grid review-anchor-fields">
                        <label>Side<select name="Side"><option value="New">New</option><option value="Old">Old</option></select></label>
                        <label>Start line<input name="StartLine" type="number" min="1" required /></label>
                        <label>End line<input name="EndLine" type="number" min="1" required /></label>
                    </div>
                    <label>Comment<textarea name="Body" rows="4" maxlength="65536" required></textarea></label>
                    <button class="btn btn-primary" type="submit"><i data-lucide="message-square-plus"></i> Start thread</button>
                </form>
            </details>
        }
    </section>
}
@if (Model.ReviewThreads.Any(thread => thread.IsOutdated))
{
    <section class="outdated-review-threads">
        <h2>Outdated review threads</h2>
        @foreach (var thread in Model.ReviewThreads.Where(thread => thread.IsOutdated))
        {
            <article class="review-thread is-outdated" id="review-thread-@thread.Id">
                <header><strong>@thread.OriginalPath · @thread.OriginalSide @thread.OriginalStartLine-@thread.OriginalEndLine</strong><span>Outdated</span></header>
                @foreach (var comment in thread.Comments)
                {
                    <div class="review-comment"><div><strong>@comment.Author</strong><time>@comment.CreatedAtUtc.ToString("u")</time></div><div class="markdown-body">@Html.Raw(comment.BodyHtml)</div></div>
                }
                @if (Model.CanReview)
                {
                    <form class="review-reply-form" asp-action="AddReviewReply" asp-route-namespaceSlug="@Model.Repository.NamespaceSlug" asp-route-project="@Model.Repository.RepositorySlug" asp-route-number="@Model.PullRequest.Number" asp-route-threadId="@thread.Id" method="post"><textarea name="Body" rows="2" maxlength="65536" required aria-label="Review reply"></textarea><button class="btn btn-primary" type="submit"><i data-lucide="reply"></i> Reply</button></form>
                }
            </article>
        }
    </section>
}
