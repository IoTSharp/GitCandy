@model TodoIndexViewModel
@{ ViewData["Title"] = "Todos"; }
<header class="page-heading"><div><h1>Todos</h1><p>Actionable work stays here until completed, snoozed, or resolved at its source.</p></div></header>
@if (Model.Page.Items.Count == 0) { <section class="empty-state"><div><i data-lucide="circle-check"></i><h2>No pending todos</h2></div></section> }
else { <div class="workspace-list">@foreach (var item in Model.Page.Items) { <article><span class="item-icon"><i data-lucide="@(item.Status == GitCandy.Workspace.WorkspaceTodoStatus.Completed ? "circle-check" : "circle-dot")"></i></span><div><a href="@item.Url"><strong>@item.Title</strong></a><p>@item.Kind · @item.Status@if (item.SnoozedUntilUtc is not null) { <text> · snoozed until @item.SnoozedUntilUtc.Value.ToString("u")</text> }</p></div><div class="row-actions">@if (item.Status == GitCandy.Workspace.WorkspaceTodoStatus.Completed) { <form asp-action="RestoreTodo" asp-route-id="@item.Id" asp-route-version="@item.Version" method="post"><button class="icon-button" type="submit" aria-label="Restore todo" data-tooltip="Restore"><i data-lucide="rotate-ccw"></i></button></form> } else { <form asp-action="SnoozeTodo" asp-route-id="@item.Id" asp-route-version="@item.Version" asp-route-days="1" method="post"><button class="icon-button" type="submit" aria-label="Snooze for one day" data-tooltip="Snooze one day"><i data-lucide="clock-3"></i></button></form><form asp-action="CompleteTodo" asp-route-id="@item.Id" asp-route-version="@item.Version" method="post"><button class="icon-button" type="submit" aria-label="Complete todo" data-tooltip="Complete"><i data-lucide="check"></i></button></form> }</div></article> }</div> }
