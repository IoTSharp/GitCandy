@model SetPasswordViewModel
@{
    ViewData["Title"] = "Add password";
}

<section class="account-shell">
    <h1>Add password</h1>
    <form asp-action="SetPassword" method="post" class="account-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-field">
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" autocomplete="new-password" autofocus />
            <span asp-validation-for="NewPassword"></span>
        </div>
        <div class="form-field">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword"></span>
        </div>
        <div class="form-actions">
            <button type="submit" class="primary-button">Add password</button>
            <a asp-action="Security">Cancel</a>
        </div>
    </form>
</section>
