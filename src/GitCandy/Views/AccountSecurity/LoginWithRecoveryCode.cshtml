@model RecoveryCodeLoginViewModel
@{
    ViewData["Title"] = "Recovery code";
    var returnUrl = ViewData["returnUrl"] as string;
}

<section class="account-shell">
    <h1>Recovery code</h1>
    <form asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@returnUrl" method="post" class="account-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <div class="form-field">
            <label asp-for="RecoveryCode"></label>
            <input asp-for="RecoveryCode" autocomplete="one-time-code" autofocus />
            <span asp-validation-for="RecoveryCode"></span>
        </div>
        <div class="form-actions">
            <button type="submit" class="primary-button">Sign in</button>
        </div>
    </form>
</section>
